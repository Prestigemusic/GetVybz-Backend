rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Match any file uploaded under a user folder
    match /users/{userId}/{allPaths=**} {
      
      // Only the owner (authenticated user) can read/write their own files
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}

{
  "name": "getvybz",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run start:mobile\" \"npm run start:backend\"",
    "start:mobile": "cd mobile && expo start --clear",
    "start:backend": "cd backend && npm run dev",
    "install:all": "npm install && cd mobile && npm install && cd ../backend && npm install && cd ../admin-dashboard && npm install",
    "migrate": "cd backend && npx sequelize-cli db:migrate"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "typescript": "~5.8.3",
    "@types/react": "~19.0.10"
  }
}
